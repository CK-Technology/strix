# Strix Configuration
# Copy this file to .env and customize as needed
#
# Required variables are marked with (required)
# Optional variables show their defaults

# =============================================================================
# REQUIRED
# =============================================================================

# Root admin credentials (required)
STRIX_ROOT_USER=admin
STRIX_ROOT_PASSWORD=changeme

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Listen addresses (internal container ports, use port mapping to change external)
# STRIX_ADDRESS=0.0.0.0:9000
# STRIX_CONSOLE_ADDRESS=0.0.0.0:9001
# STRIX_METRICS_ADDRESS=0.0.0.0:9090

# External port mappings (for docker-compose)
# STRIX_PORT_S3=9000
# STRIX_PORT_CONSOLE=9001
# STRIX_PORT_METRICS=9090

# Data directory (inside container)
# STRIX_DATA_DIR=/var/lib/strix

# =============================================================================
# SECURITY
# =============================================================================

# JWT secret for admin session tokens (base64-encoded, min 32 bytes)
# If not set, sessions reset on restart
# Generate with: openssl rand -base64 32
# STRIX_JWT_SECRET=

# =============================================================================
# LOGGING & TELEMETRY
# =============================================================================

# Log level: trace, debug, info, warn, error
STRIX_LOG_LEVEL=info

# Output logs as JSON (for log aggregators)
STRIX_LOG_JSON=false

# OpenTelemetry OTLP endpoint (e.g., http://jaeger:4317)
# STRIX_OTLP_ENDPOINT=

# Service name for telemetry
# STRIX_SERVICE_NAME=strix

# =============================================================================
# S3 API SETTINGS
# =============================================================================

# Rate limit for S3 API requests per second
# STRIX_S3_RATE_LIMIT=1000

# Multipart upload expiry in hours
# STRIX_MULTIPART_EXPIRY_HOURS=24

# =============================================================================
# OIDC / SSO (Optional)
# =============================================================================

# OpenID Connect issuer URL
# STRIX_OIDC_ISSUER=

# OIDC client credentials
# STRIX_OIDC_CLIENT_ID=
# STRIX_OIDC_CLIENT_SECRET=

# Redirect URI after OIDC login
# STRIX_OIDC_REDIRECT_URI=

# Claim to use for username (default: preferred_username)
# STRIX_OIDC_USERNAME_CLAIM=preferred_username

# Auto-create users on first OIDC login
# STRIX_OIDC_AUTO_CREATE=false

# =============================================================================
# MONITORING (docker-compose --profile monitoring)
# =============================================================================

# Grafana admin credentials
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=admin
